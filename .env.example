# Storacha / Filecoin
# Agent private key (from `storacha key create`)
STORACHA_PRIVATE_KEY=MgCY_your_ed25519_private_key_here
# UCAN delegation proof (from `storacha delegation create <did> --base64`)
STORACHA_PROOF=your_base64_encoded_ucan_delegation_proof_here
# (Optional) CID of the persisted dataset registry
STORACHA_REGISTRY_CID=
# Public space DID (informational, derived from proof)
NEXT_PUBLIC_STORACHA_SPACE_DID=did:key:your_space_did_here

# Lit Protocol
NEXT_PUBLIC_LIT_NETWORK=datil-dev
LIT_AUTH_PRIVATE_KEY=your_lit_auth_private_key_here

# Flow Blockchain
NEXT_PUBLIC_FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
NEXT_PUBLIC_FLOW_DISCOVERY_WALLET=https://fcl-discovery.onflow.org/testnet/authn
FLOW_ACCOUNT_ADDRESS=0xYOUR_FLOW_ADDRESS
FLOW_PRIVATE_KEY=your_flow_private_key_here
NEXT_PUBLIC_FLOW_REGISTRY_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# NEAR Protocol
NEXT_PUBLIC_NEAR_NETWORK_ID=testnet
NEXT_PUBLIC_NEAR_NODE_URL=https://rpc.testnet.near.org
NEAR_ACCOUNT_ID=your_account.testnet
NEAR_PRIVATE_KEY=your_near_private_key_here
NEXT_PUBLIC_NEAR_CONTRACT_ID=your_contract.testnet

# World ID (Proof of Personhood)
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_ACTION=verify-neurovault-user

# Impulse AI (optional — falls back to built-in ERD classifier)
NEXT_PUBLIC_IMPULSE_API_KEY=your_impulse_api_key_here
NEXT_PUBLIC_IMPULSE_ENDPOINT=https://api.impulselabs.ai/v1
NEXT_PUBLIC_IMPULSE_MODEL_ID=your_model_id_here
