# ═══════════════════════════════════════════════════════════════════
# NeuroVault — Environment Configuration
# Copy this file to .env and fill in your values.
# All integrations have demo fallbacks — the app runs without keys.
# ═══════════════════════════════════════════════════════════════════

# ── Storacha / Filecoin ──────────────────────────────────────────
# Decentralized storage for encrypted EEG data and metadata.
# Generate keys: `npx storacha key create`
# Generate proof: `npx storacha delegation create <agent-did> --base64`

# Ed25519 private key for the Storacha agent (base64-encoded)
STORACHA_PRIVATE_KEY=MgCY_your_ed25519_private_key_here

# UCAN delegation proof granting the agent write access to your space
STORACHA_PROOF=your_base64_encoded_ucan_delegation_proof_here

# (Optional) CID of the persisted dataset registry JSON
STORACHA_REGISTRY_CID=

# Public space DID — derived from the delegation proof (informational)
NEXT_PUBLIC_STORACHA_SPACE_DID=did:key:your_space_did_here

# ── Lit Protocol ─────────────────────────────────────────────────
# Programmable encryption & access control for EEG data.
# Falls back to Web Crypto AES-GCM if unavailable.

# Lit network to connect to (datil-dev = testnet)
NEXT_PUBLIC_LIT_NETWORK=datil-dev

# (Optional) Auth private key for Lit authentication
LIT_AUTH_PRIVATE_KEY=your_lit_auth_private_key_here

# ── Flow Blockchain ─────────────────────────────────────────────
# On-chain dataset registry, licensing, and contributor payments.
# Uses Flow EVM Testnet (Chain ID: 545).

# Flow EVM RPC endpoint
NEXT_PUBLIC_FLOW_ACCESS_NODE=https://rest-testnet.onflow.org

# FCL wallet discovery URL
NEXT_PUBLIC_FLOW_DISCOVERY_WALLET=https://fcl-discovery.onflow.org/testnet/authn

# Server-side Flow account (for contract deployment)
FLOW_ACCOUNT_ADDRESS=0xYOUR_FLOW_ADDRESS
FLOW_PRIVATE_KEY=your_flow_private_key_here

# Deployed NeuroVaultRegistry contract address
# Leave empty for demo mode (in-memory datasets)
NEXT_PUBLIC_FLOW_REGISTRY_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── NEAR Protocol ───────────────────────────────────────────────
# AI-powered dataset matching with on-chain scoring transparency.
# Contract deployed to neurovault-matcher.testnet.

# NEAR network (testnet or mainnet)
NEXT_PUBLIC_NEAR_NETWORK_ID=testnet

# NEAR RPC endpoint
NEXT_PUBLIC_NEAR_NODE_URL=https://rpc.testnet.near.org

# Server-side NEAR account (for contract interactions)
NEAR_ACCOUNT_ID=your_account.testnet
NEAR_PRIVATE_KEY=your_near_private_key_here

# Deployed DatasetMatcher contract ID
NEXT_PUBLIC_NEAR_CONTRACT_ID=your_contract.testnet

# ── World ID ────────────────────────────────────────────────────
# Proof of personhood to prevent Sybil attacks.
# Register at https://developer.worldcoin.org to get an app ID.
# Leave empty for demo mode (auto-verify bypass).

# World ID application ID (from World Developer Portal)
NEXT_PUBLIC_WORLD_APP_ID=

# Action name for verification (must match Developer Portal config)
NEXT_PUBLIC_WORLD_ACTION=verify-neurovault-user

# ── Impulse AI (Optional) ──────────────────────────────────────
# Motor imagery classification from EEG signals.
# Falls back to built-in ERD (Event-Related Desynchronization) classifier.

# Impulse AI API key
NEXT_PUBLIC_IMPULSE_API_KEY=your_impulse_api_key_here

# Impulse AI API endpoint
NEXT_PUBLIC_IMPULSE_ENDPOINT=https://api.impulselabs.ai/v1

# Fine-tuned model ID for EEG classification
NEXT_PUBLIC_IMPULSE_MODEL_ID=your_model_id_here
